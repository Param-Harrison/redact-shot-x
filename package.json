{
  "name": "redact-shot-x",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "start": "bash run-dev.sh",
    "build:mac": "python build.py --target mac",
    "build:linux": "bash scripts/build-linux.sh",
    "build:win": "bash scripts/build-win.sh",
    "build:all": "npm run build && npm run build:mac && npm run build:linux && npm run build:win"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.3.6"
  }
}
