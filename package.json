{
  "name": "redact-shot-x",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "web": "vite --config vite.web.config.ts",
    "build:web": "tsc && vite build --config vite.web.config.ts",
    "build:sidecar-windows": "pyinstaller -c -F --clean --name api-x86_64-pc-windows-msvc --distpath src-tauri/bin/ src-python/api.py",
    "build:sidecar-mac": "pyinstaller -c -F --clean --name api-aarch64-apple-darwin --distpath src-tauri/bin/ src-python/api.py",
    "build:sidecar-mac-intel": "pyinstaller -c -F --clean --name api-x86_64-apple-darwin --distpath src-tauri/bin/ src-python/api.py",
    "build:sidecar-linux": "pyinstaller -c -F --clean --name api-x86_64-unknown-linux-gnu --distpath src-tauri/bin/ src-python/api.py",
    "build:sidecar": "pnpm build:sidecar-mac",
    "build:sidecar-all": "pnpm build:sidecar-windows && pnpm build:sidecar-mac && pnpm build:sidecar-mac-intel && pnpm build:sidecar-linux",
    "tauri:dev": "pnpm build:sidecar && pnpm tauri dev",
    "tauri:build": "pnpm build:sidecar-all && pnpm tauri build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-shell": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "@tauri-apps/cli": "^2"
  }
}
